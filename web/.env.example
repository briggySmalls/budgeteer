# Google integration. Copy this file to `.env.local` (gitignored) and fill in both values.
# Both are public (they ship in the client bundle) — not secrets in the security sense.

# OAuth client ID (Web application), for sign-in.
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# API key (developer key) with the Picker API enabled, for the native file picker.
VITE_GOOGLE_API_KEY=your-api-key
